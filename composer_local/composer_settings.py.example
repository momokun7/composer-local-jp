"""
このファイルは、ローカル環境の Composer 設定を管理します。
Cloud Composer の設定をこのファイルに同期することで、ローカル環境の Composer 設定を管理できます。

このファイルの設定は以下の場所で使用されます：
- Makefile: 環境作成、認証、変数同期などのコマンド
- CLI: composer-local コマンドのデフォルト値
- 各種スクリプト: プロジェクトID、サービスアカウントなどの参照

使い方:
  1. このファイルを composer_settings.py にコピーする
  2.「ローカル環境設定（必須）」セクションを必要に応じて変更する
  3. GCP 連携が必要な場合は「GCP 連携設定（オプション）」のコメントアウトを解除する
  4. 詳細設定はデフォルト値のまま動作するため、必要な場合のみ変更する

GCP 連携なしでもローカル Airflow 環境は動作します。
GCP 連携が必要な場合は下記の「GCP 連携設定（オプション）」セクションの
コメントアウトを解除して値を設定してください。
"""

# #############################################################################
#  ローカル環境設定（必須）
#  ローカル Airflow 環境の基本設定。GCP 連携なしでも使用される項目。
# #############################################################################

# ローカル環境名
# Docker コンテナ名やネットワーク名のサフィックスとして使用される。
# 複数環境を同時に起動する場合は、それぞれ異なる名前を指定すること。
# 有効値: 英数字・ハイフン・アンダースコア
# デフォルト値: "my-local-env"
LOCAL_ENV_NAME = "my-local-env"

# ローカル環境の Web サーバーポート番号
# Airflow の Web UI にアクセスする際のポート。
# 有効範囲: 1024-65535
# デフォルト値: 8080
# 関連設定: この値を変更した場合、AIRFLOW_URL のポート番号も合わせて変更すること
LOCAL_PORT = 8080

# Cloud Composer のイメージバージョン
# ローカル環境で使用する Composer Docker イメージのバージョンを指定する。
# `make sync-settings` で Cloud Composer 環境から自動同期される。
# 形式: "composer-{メジャー}-airflow-{バージョン}-build.{ビルド番号}"
# デフォルト値: "composer-3-airflow-2.10.5-build.13"
COMPOSER_IMAGE_VERSION = "composer-3-airflow-2.10.5-build.13"

# Composer イメージで報告される Python のメジャー/マイナーバージョン（文字列）
# `make sync-settings` で自動設定されるため、通常は空文字列のままでよい。
# 形式: "3.11" のようなメジャー.マイナー形式、または空文字列（自動検出）
# デフォルト値: ""（空文字列 = イメージのデフォルトを使用）
COMPOSER_PYTHON_VERSION = ""

# DAG ディレクトリのパス（相対パスまたは絶対パス）
# DAG ファイルを格納するディレクトリ。相対パスの場合はプロジェクトルートからの相対パス。
# Makefile では $(PWD)/dags として展開されるため、相対パスで設定することを推奨。
# デフォルト値: "dags"
DAGS_PATH = "dags"

# #############################################################################
#  GCP 連携設定（オプション）
#  Cloud Composer 環境との同期や Secret Manager 連携を使用する場合に設定する。
#  GCP 連携を使う場合はコメントアウトを解除して値を設定してください。
#  詳細は docs/gcp-integration.md を参照。
# #############################################################################

# ---------- Cloud Composer 環境の識別情報 ----------
# `make sync-settings` や `make sync-vars` で使用される。

# Cloud Composer 環境名
# GCP コンソールの Cloud Composer ページで確認可能。
# デフォルト値: ""（空文字列 = GCP 連携無効）
# COMPOSER_ENV_NAME = ""

# Cloud Composer 環境のロケーション
# 例: "asia-northeast1", "us-central1"
# デフォルト値: ""（空文字列 = GCP 連携無効）
# COMPOSER_LOCATION = ""

# ---------- Google Cloud プロジェクト設定 ----------

# GCP プロジェクト ID
# `gcloud config get-value project` でも確認可能。
# デフォルト値: ""（空文字列 = GCP 連携無効）
# PROJECT_ID = ""

# サービスアカウントのメールアドレス
# Airflow が GCP リソースにアクセスする際に使用する。
# 形式: "<サービスアカウント名>@<プロジェクトID>.iam.gserviceaccount.com"
# デフォルト値: ""（空文字列 = 未設定）
# SERVICE_ACCOUNT = ""

# ---------- Secret Manager 設定（sync-vars-sm 使用時のみ必要）----------

# Airflow Variables を格納する Secret Manager のシークレット ID
# `make sync-vars-sm` で Secret Manager から変数を同期する際に使用される。
# 関連設定: PROJECT_ID が設定されている必要がある
# デフォルト値: ""（空文字列 = 未設定）
# SECRET_ID = ""

# #############################################################################
#  Airflow 設定
#  ローカル Airflow Web サーバーの URL と管理者アカウント。
# #############################################################################

# ローカル Airflow の URL
# CLI や変数インポートスクリプトが Airflow API にアクセスする際に使用する。
# 形式: "http://<ホスト>:<ポート>"
# デフォルト値: "http://localhost:8080"
# 関連設定: LOCAL_PORT を変更した場合、この URL のポート番号も合わせて変更すること
AIRFLOW_URL = "http://localhost:8080"

# 管理者ユーザーのデフォルト設定
# ローカル環境の初回起動時に作成される管理者アカウント。
# 本番環境と同じ認証情報は絶対に使用しないこと。
# デフォルト値: 下記の通り
ADMIN_USERNAME = "admin"
ADMIN_PASSWORD = "admin"
ADMIN_EMAIL = "admin@example.com"
ADMIN_FIRSTNAME = "Admin"
ADMIN_LASTNAME = "User"

# #############################################################################
#  データベース設定
#  Airflow のメタデータを格納するバックエンドデータベース。
# #############################################################################

# データベースエンジン
# 有効値: "postgresql" または "mysql"
# デフォルト値: "postgresql"
DATABASE_ENGINE = "postgresql"

# PostgreSQL 接続設定
# Docker コンテナ内の PostgreSQL に接続するための設定。
# ローカル開発用のため、本番環境のパスワードは使用しないこと。
# デフォルト値: 下記の通り
POSTGRES_USER = "postgres"
POSTGRES_PASSWORD = "airflow"
POSTGRES_DB = "airflow"

# PostgreSQL のコンテナ内部ポート番号
# Docker コンテナ内で PostgreSQL が待ち受けるポート。通常は変更不要。
# 有効範囲: 1024-65535
# デフォルト値: 5432
POSTGRES_PORT = 5432

# PostgreSQL のホスト側公開ポート番号
# ホストマシンから PostgreSQL に直接接続する際のポート（デバッグ用途など）。
# 他のサービスとポートが衝突する場合に変更する。
# 有効範囲: 1024-65535
# デフォルト値: 25432
# 関連設定: POSTGRES_PORT（コンテナ内部）とは別の値であること
POSTGRES_LOCAL_PORT = 25432

# DAG ディレクトリの再読み込み間隔（秒）
# Airflow スケジューラーが DAG ファイルの変更を検出する間隔。
# 値を小さくすると変更が素早く反映されるが、CPU 負荷が増加する。
# 有効範囲: 1 以上の整数
# デフォルト値: 10
DAG_DIR_LIST_INTERVAL = 10

# #############################################################################
#  同期・監視設定
#  Secret Manager の同期間隔や Web サーバー起動時のタイムアウト。
# #############################################################################

# Secret Manager 同期間隔（秒）
# Secret Manager から Airflow Variables を定期同期する間隔。
# 値を大きくすると API 呼び出しが減るが、変数の反映が遅れる。
# 有効範囲: 60 以上の整数を推奨
# デフォルト値: 300（5分）
# 関連設定: SECRET_ID が設定されている場合のみ有効
SYNC_INTERVAL = 300

# Web サーバー起動待機タイムアウト（秒）
# 環境起動時に Web サーバーが応答するまで待機する最大時間。
# 初回起動時はデータベースのマイグレーションがあるため時間がかかる場合がある。
# 有効範囲: 60 以上の整数を推奨
# デフォルト値: 300（5分）
# 関連設定: WEBSERVER_CHECK_INTERVAL と組み合わせて使用される
WEBSERVER_TIMEOUT = 300

# Web サーバー起動確認間隔（秒）
# 起動待機中に Web サーバーの応答を確認するポーリング間隔。
# 有効範囲: 1 以上の整数
# デフォルト値: 2
# 関連設定: WEBSERVER_TIMEOUT と組み合わせて使用される
WEBSERVER_CHECK_INTERVAL = 2

# #############################################################################
#  Docker 設定
#  Docker コンテナのリソース制限やネットワーク設定。
# #############################################################################

# Docker コンテナのメモリ制限
# Airflow コンテナおよび PostgreSQL コンテナの両方に適用される。
# DAG の数や複雑さに応じて調整すること。
# 形式: "<数値><単位>" （例: "2g", "4g", "512m"）
#   単位: "b"=バイト, "k"=キロバイト, "m"=メガバイト, "g"=ギガバイト
# デフォルト値: "4g"
DOCKER_MEMORY_LIMIT = "4g"

# ポートバインディング設定
# True の場合、Web サーバーのポートは 127.0.0.1（localhost）のみにバインドされる。
# False にすると 0.0.0.0 にバインドされ、外部ネットワークからアクセス可能になる。
# セキュリティ上、True を推奨。False にする場合はファイアウォール設定を確認すること。
# 有効値: True または False
# デフォルト値: True
BIND_TO_LOCALHOST_ONLY = True

# PostgreSQL の Docker イメージ
# メタデータデータベースとして使用する PostgreSQL のイメージタグ。
# 形式: "<イメージ名>:<タグ>"
# デフォルト値: "postgres:14-alpine"
POSTGRES_IMAGE = "postgres:14-alpine"

# #############################################################################
#  Variables 処理設定
#  Airflow Variables のインポート・エクスポート時の並列処理やマスキング。
# #############################################################################

# 並列処理の最大ワーカー数
# Secret Manager からの変数同期時に使用する並列スレッド数の上限。
# 同期する変数の数とこの値の小さい方が実際のスレッド数になる。
# 有効範囲: 1 以上の整数
# デフォルト値: 10
MAX_PARALLEL_WORKERS = 10

# Variables 値のマスキング設定
# ログ出力時に変数値を部分的にマスクして表示する際の設定。
# 例: MASK_PREFIX_LENGTH=4, MASK_SUFFIX_LENGTH=4 の場合
#   "my-secret-value-12345" → "my-s***********2345"
# 有効範囲: 0 以上の整数
# デフォルト値: 4（先頭4文字を表示）
MASK_PREFIX_LENGTH = 4
# デフォルト値: 4（末尾4文字を表示）
MASK_SUFFIX_LENGTH = 4
