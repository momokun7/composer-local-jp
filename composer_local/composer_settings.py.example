"""
ローカル環境の Composer 設定ファイル。

使い方:
  1. このファイルを composer_settings.py にコピー
  2. 必要に応じて設定値を変更（デフォルト値のまま動作可能）
"""

# --- ローカル環境 ---

# 環境名（コンテナ名のサフィックスになります）
LOCAL_ENV_NAME = "my-local-env"

# Airflow Web UI のポート番号
LOCAL_PORT = 8080

# Composer Docker イメージバージョン（make sync-settings で自動同期可能）
COMPOSER_IMAGE_VERSION = "composer-3-airflow-2.10.5-build.13"

# Python バージョン（空文字列 = イメージのデフォルトを使用）
COMPOSER_PYTHON_VERSION = ""

# DAG ディレクトリのパス（プロジェクトルートからの相対パス）
DAGS_PATH = "dags"

# --- GCP 連携（オプション。使う場合はコメントアウトを解除） ---
# 詳細は docs/gcp-integration.md を参照

# PROJECT_ID = ""
# COMPOSER_LOCATION = ""       # 例: "asia-northeast1"
# COMPOSER_ENV_NAME = ""
# SERVICE_ACCOUNT = ""         # サービスアカウントのメールアドレス
# SECRET_ID = ""               # Secret Manager のシークレット ID

# --- Airflow ---

AIRFLOW_URL = "http://localhost:8080"

# 管理者アカウント（ローカル開発専用）
ADMIN_USERNAME = "admin"
ADMIN_PASSWORD = "admin"
ADMIN_EMAIL = "admin@example.com"
ADMIN_FIRSTNAME = "Admin"
ADMIN_LASTNAME = "User"

# --- データベース ---

DATABASE_ENGINE = "postgresql"
POSTGRES_USER = "postgres"
POSTGRES_PASSWORD = "airflow"
POSTGRES_DB = "airflow"
POSTGRES_PORT = 5432
POSTGRES_LOCAL_PORT = 25432    # ホスト側の公開ポート（デバッグ用）

# --- 詳細設定（通常は変更不要） ---

DAG_DIR_LIST_INTERVAL = 10    # DAG ディレクトリの再読み込み間隔（秒）
SYNC_INTERVAL = 300           # Secret Manager 同期間隔（秒）
WEBSERVER_TIMEOUT = 300       # Web サーバー起動待機タイムアウト（秒）
WEBSERVER_CHECK_INTERVAL = 2  # Web サーバー起動確認の間隔（秒）
DOCKER_MEMORY_LIMIT = "4g"    # コンテナのメモリ制限
BIND_TO_LOCALHOST_ONLY = True  # True: localhost のみ、False: 外部アクセス可能
POSTGRES_IMAGE = "postgres:14-alpine"
MAX_PARALLEL_WORKERS = 10     # Secret Manager 同期の並列ワーカー数
MASK_PREFIX_LENGTH = 4        # ログ出力時のマスキング（先頭表示文字数）
MASK_SUFFIX_LENGTH = 4        # ログ出力時のマスキング（末尾表示文字数）
