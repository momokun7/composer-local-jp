"""
このファイルは、ローカル環境の Composer 設定を管理します。
Cloud Composer の設定をこのファイルに同期することで、ローカル環境の Composer 設定を管理できます。

このファイルの設定は以下の場所で使用されます：
- Makefile: 環境作成、認証、変数同期などのコマンド
- CLI: composer-local コマンドのデフォルト値
- 各種スクリプト: プロジェクトID、サービスアカウントなどの参照
"""

# =============================================================================
# Cloud Composer 環境設定（オプション: GCP 連携時のみ必要）
# =============================================================================

# Cloud Composer 環境の識別情報（空欄の場合は GCP 連携をスキップ）
COMPOSER_ENV_NAME = ""
COMPOSER_LOCATION = ""

# ランタイム/ツールバージョン
COMPOSER_IMAGE_VERSION = "composer-3-airflow-2.10.5-build.13"

# Composer イメージで報告される Python のメジャー/マイナーバージョン（文字列）
COMPOSER_PYTHON_VERSION = ""

# =============================================================================
# Google Cloud プロジェクト設定（オプション: GCP 連携時のみ必要）
# =============================================================================

# プロジェクトID（staging環境）
PROJECT_ID = ""

# サービスアカウント設定
SERVICE_ACCOUNT = ""

# =============================================================================
# ローカル環境設定
# =============================================================================

# ローカル環境名
LOCAL_ENV_NAME = "my-local-env"

# ローカル環境のポート
LOCAL_PORT = 8080

# DAGディレクトリのパス（相対パスまたは絶対パス）
# Makefileでは $(PWD)/dags として使用されるため、相対パスで設定
DAGS_PATH = "dags"

# =============================================================================
# Secret Manager 設定
# =============================================================================

# Airflow Variables を格納する Secret の ID（オプション: sync-vars-sm 使用時のみ必要）
SECRET_ID = ""

# =============================================================================
# Airflow 設定
# =============================================================================

# ローカル Airflow の URL
AIRFLOW_URL = "http://localhost:8080"

# 管理者ユーザーのデフォルト設定
ADMIN_USERNAME = "admin"
ADMIN_PASSWORD = "admin"
ADMIN_EMAIL = "admin@example.com"
ADMIN_FIRSTNAME = "Admin"
ADMIN_LASTNAME = "User"

# =============================================================================
# データベース設定
# =============================================================================

# データベースエンジン（postgresql または mysql）
DATABASE_ENGINE = "postgresql"

# PostgreSQL設定
POSTGRES_USER = "postgres"
POSTGRES_PASSWORD = "airflow"
POSTGRES_DB = "airflow"
POSTGRES_PORT = 5432
POSTGRES_LOCAL_PORT = 25432

# DAGディレクトリのリスト間隔（秒）
DAG_DIR_LIST_INTERVAL = 10

# =============================================================================
# 同期・監視設定
# =============================================================================

# Secret Manager 同期間隔（秒）
SYNC_INTERVAL = 300  # 5 minutes

# Webサーバー起動待機タイムアウト（秒）
WEBSERVER_TIMEOUT = 300

# Webサーバー起動確認間隔（秒）
WEBSERVER_CHECK_INTERVAL = 2

# =============================================================================
# Docker設定
# =============================================================================

# メモリ制限（バイト）
DOCKER_MEMORY_LIMIT = "4g"

# ポートバインディング設定
# Webサーバーは localhost のみにバインド（セキュリティのため）
BIND_TO_LOCALHOST_ONLY = True

# PostgreSQL イメージ
POSTGRES_IMAGE = "postgres:14-alpine"

# =============================================================================
# Variables 処理設定
# =============================================================================

# 並列処理のワーカー数（最大）
MAX_PARALLEL_WORKERS = 10

# Variables 値のマスキング設定
MASK_PREFIX_LENGTH = 4  # 先頭何文字を表示するか
MASK_SUFFIX_LENGTH = 4  # 末尾何文字を表示するか
